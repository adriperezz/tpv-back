{
  "files.exclude": {
    ".mule": true,
    "**/.apivcs": true,
    "**/.designer.json": true,
    "**/.DS_Store": true,
    "**/.exchange_modules_tmp": true,
    "**/.exchange.xml": true,
    "**/.git": false,
    "**/.hg": true,
    "**/.mvn": true,
    "**/.svn": true,
